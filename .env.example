# Project Zenith - Environment Variables

# ========================
# Frontend (Next.js)
# ========================
# NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here
# NEXT_PUBLIC_API_URL=http://localhost:8080

# ========================
# Backend (Golang)
# ========================
# PORT=8080
# CLICKHOUSE_URL=tcp://your-cloud-db-host:9000?debug=true
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=your_password
# CLICKHOUSE_DATABASE=zenith

# ========================
# Telemetry APIs
# ========================
# Data Ingestion
HORIZONS_API_URL="https://ssd.jpl.nasa.gov/api/horizons.api"
CELESTRAK_API_URL="https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=tle"
